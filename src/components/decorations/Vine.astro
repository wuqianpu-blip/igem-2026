---
export interface Props {
  class?: string;
  width?: number;
  height?: number;
  color?: string;
  flipped?: boolean;
  style?: string;
}

const { class: className, width = 200, height = 300, color = '#4A7C59', flipped = false } = Astro.props;
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 200 300"
  fill="none"
  style={`${flipped ? 'transform: scaleX(-1);' : ''} ${Astro.props.style || ''}`}
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M100 0 C80 50, 130 80, 110 130 C90 180, 140 210, 120 260 C100 310, 150 340, 130 400"
    stroke={color}
    stroke-width="4"
    fill="none"
    opacity="0.6"
  />
  <path d="M40 30 C50 20, 60 25, 55 40" stroke={color} stroke-width="3" fill="none" opacity="0.5" />
  <ellipse cx="50" cy="35" rx="12" ry="7" fill={color} opacity="0.4" transform="rotate(-20 50 35)" />
  <path d="M150 60 C140 50, 130 55, 135 70" stroke={color} stroke-width="3" fill="none" opacity="0.5" />
  <ellipse cx="140" cy="65" rx="10" ry="6" fill={color} opacity="0.4" transform="rotate(15 140 65)" />
  <path d="M60 150 C70 140, 80 145, 75 160" stroke={color} stroke-width="3" fill="none" opacity="0.5" />
  <ellipse cx="70" cy="155" rx="12" ry="7" fill={color} opacity="0.4" transform="rotate(-30 70 155)" />
  <path d="M160 200 C150 190, 140 195, 145 210" stroke={color} stroke-width="3" fill="none" opacity="0.5" />
  <ellipse cx="150" cy="205" rx="11" ry="6" fill={color} opacity="0.4" transform="rotate(25 150 205)" />
  <path d="M80 250 C90 240, 100 245, 95 260" stroke={color} stroke-width="3" fill="none" opacity="0.5" />
  <ellipse cx="90" cy="255" rx="10" ry="6" fill={color} opacity="0.4" transform="rotate(-15 90 255)" />
</svg>
