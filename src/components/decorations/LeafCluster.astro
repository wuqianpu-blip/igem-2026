---
export interface Props {
  class?: string;
  width?: number;
  height?: number;
  style?: string;
}

const { class: className, width = 150, height = 150 } = Astro.props;
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 150 150"
  fill="none"
  style={Astro.props.style}
  xmlns="http://www.w3.org/2000/svg"
>
  <ellipse cx="30" cy="120" rx="25" ry="12" fill="#4A7C59" opacity="0.4" transform="rotate(-40 30 120)" />
  <ellipse cx="50" cy="100" rx="22" ry="10" fill="#5A8C69" opacity="0.35" transform="rotate(-20 50 100)" />
  <ellipse cx="70" cy="130" rx="20" ry="9" fill="#6B9E7A" opacity="0.3" transform="rotate(10 70 130)" />
  <path d="M120 20 Q130 10 140 20 Q130 30 120 20Z" fill="#4A7C59" opacity="0.45" />
  <path d="M110 35 Q120 25 130 35 Q120 45 110 35Z" fill="#5A8C69" opacity="0.35" />
  <path d="M130 40 Q140 30 150 40 Q140 50 130 40Z" fill="#6B9E7A" opacity="0.3" />
  <path d="M20 30 Q35 20 40 35 Q25 40 20 30Z" fill="#C0392B" opacity="0.3" transform="rotate(15 30 30)" />
  <path d="M25 18 Q35 10 40 22 Q28 28 25 18Z" fill="#D35400" opacity="0.25" transform="rotate(-10 32 18)" />
  <ellipse cx="100" cy="90" rx="18" ry="8" fill="#4A7C59" opacity="0.3" transform="rotate(30 100 90)" />
  <ellipse cx="120" cy="80" rx="15" ry="7" fill="#5A8C69" opacity="0.25" transform="rotate(45 120 80)" />
</svg>
