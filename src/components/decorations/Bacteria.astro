---
export interface Props {
  class?: string;
  size?: number;
  color?: string;
  style?: string;
}

const { class: className, size = 80, color = '#4A7C59' } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  style={Astro.props.style}
  xmlns="http://www.w3.org/2000/svg"
>
  <ellipse cx="50" cy="50" rx="30" ry="18" fill={color} opacity="0.25" />
  <ellipse cx="50" cy="50" rx="30" ry="18" stroke={color} stroke-width="3" fill="none" opacity="0.6" />
  <circle cx="30" cy="40" r="4" fill={color} opacity="0.7" />
  <circle cx="38" cy="35" r="3" fill={color} opacity="0.7" />
  <circle cx="45" cy="38" r="3.5" fill={color} opacity="0.7" />
  <circle cx="55" cy="42" r="3" fill={color} opacity="0.7" />
  <circle cx="62" cy="39" r="4" fill={color} opacity="0.7" />
  <circle cx="70" cy="43" r="3" fill={color} opacity="0.7" />
  <path d="M50 68 L45 80 L55 80 Z" fill={color} opacity="0.4" />
  <path d="M40 66 L35 78 L45 78 Z" fill={color} opacity="0.3" />
  <path d="M60 66 L55 78 L65 78 Z" fill={color} opacity="0.3" />
  <circle cx="50" cy="65" r="5" fill={color} opacity="0.2" />
</svg>
