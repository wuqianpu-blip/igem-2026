---
export interface Props {
  class?: string;
  width?: number;
  height?: number;
  style?: string;
}

const { class: className, width = 250, height = 350 } = Astro.props;
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 250 350"
  fill="none"
  style={Astro.props.style}
  xmlns="http://www.w3.org/2000/svg"
>
  <rect x="110" y="250" width="30" height="80" rx="4" fill="#6B4226" />
  <rect x="108" y="248" width="34" height="10" rx="3" fill="#7D4E2A" />
  <ellipse cx="125" cy="180" rx="80" ry="90" fill="#4A7C59" opacity="0.7" />
  <ellipse cx="125" cy="160" rx="65" ry="70" fill="#5A8C69" opacity="0.6" />
  <ellipse cx="125" cy="140" rx="50" ry="55" fill="#6B9E7A" opacity="0.5" />
  <circle cx="90" cy="170" r="25" fill="#4A7C59" opacity="0.5" />
  <circle cx="160" cy="175" r="28" fill="#5A8C69" opacity="0.5" />
  <circle cx="125" cy="115" r="22" fill="#6B9E7A" opacity="0.4" />
  <circle cx="100" cy="145" r="15" fill="#6B9E7A" opacity="0.3" />
  <circle cx="150" cy="145" r="18" fill="#5A8C69" opacity="0.3" />
  <ellipse cx="80" cy="160" rx="12" ry="8" fill="#7BAE8A" opacity="0.4" transform="rotate(-30 80 160)" />
  <ellipse cx="170" cy="150" rx="10" ry="7" fill="#7BAE8A" opacity="0.4" transform="rotate(20 170 150)" />
  <ellipse cx="130" cy="110" rx="9" ry="6" fill="#8BBE9A" opacity="0.4" transform="rotate(-10 130 110)" />
</svg>
